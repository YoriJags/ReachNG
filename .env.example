# ReachNG — environment template
# Copy to .env locally; production values live in Railway.

# ── Core ──────────────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=

# ── Storage ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=reachng

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASS=

# ── Messaging (Unipile primary, Meta Cloud fallback) ──────────────────────────
UNIPILE_API_KEY=
UNIPILE_DSN=
UNIPILE_WHATSAPP_ACCOUNT_ID=
UNIPILE_EMAIL_ACCOUNT_ID=
UNIPILE_INSTAGRAM_ACCOUNT_ID=
UNIPILE_LINKEDIN_ACCOUNT_ID=
UNIPILE_HOSTED_NOTIFY_TOKEN=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=

# ── Webhook security (REQUIRED in production) ─────────────────────────────────
# Meta verify token: arbitrary string, must match what you configured in Meta
WEBHOOK_VERIFY_TOKEN=
# Meta App Secret: enables HMAC-SHA256 verification of inbound POSTs
META_APP_SECRET=
# Unipile custom auth header value — set the matching `Unipile-Auth: <value>`
# header on every webhook configured in the Unipile dashboard.
UNIPILE_WEBHOOK_SECRET=

# ── Discovery (internal Prospect OS only — never billed to clients) ───────────
GOOGLE_MAPS_API_KEY=
APOLLO_API_KEY=
APIFY_API_TOKEN=
TWITTER_BEARER_TOKEN=
FB_ADS_ACCESS_TOKEN=
DEFAULT_CITY=Lagos

# ── Email (Resend primary, Gmail SMTP fallback) ───────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@reachng.ng
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
SMTP_HOST=
SMTP_PORT=465
SMTP_USE_SSL=true
IMAP_HOST=
IMAP_PORT=993

# ── Billing ───────────────────────────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# ── Analytics / Notifications ─────────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SLACK_WEBHOOK_URL=
OWNER_WHATSAPP=

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Keep false locally/tests; set true explicitly in Railway production.
SCHEDULER_ENABLED=false

# ── Outreach tuning ───────────────────────────────────────────────────────────
DAILY_SEND_LIMIT=80
FOLLOWUP_DELAY_HOURS=72
MAX_FOLLOWUP_ATTEMPTS=2
EMAIL_COOLDOWN_DAYS=14
LEAD_REFRESH_DAYS=30
CITY_EXPAND_THRESHOLD=0.4
