# ─── Claude (Anthropic) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ─── Unipile (WhatsApp + Email) ───────────────────────────────────────────────
UNIPILE_API_KEY=...
UNIPILE_DSN=...                         # e.g. api4.unipile.com:13465
UNIPILE_WHATSAPP_ACCOUNT_ID=...         # Your connected WhatsApp account ID
UNIPILE_EMAIL_ACCOUNT_ID=...            # Your connected email account ID

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=reachng

# ─── Campaign Settings ────────────────────────────────────────────────────────
DEFAULT_CITY=Lagos, Nigeria
DAILY_SEND_LIMIT=50                     # Max outreach messages per day
FOLLOWUP_DELAY_HOURS=48                 # Hours before follow-up
MAX_FOLLOWUP_ATTEMPTS=2                 # Max follow-ups per contact

# ─── Owner Notifications ─────────────────────────────────────────────────────
OWNER_WHATSAPP=+2348012345678           # Your personal WhatsApp — alerts on reply
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...  # Optional Slack alerts

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development                     # development | production
APP_PORT=8000
LOG_LEVEL=INFO
